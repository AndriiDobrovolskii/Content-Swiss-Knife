# LLM Provider: "openai" | "anthropic" | "gemini"
LLM_PROVIDER=anthropic

# OpenAI (fallback)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic (active — Deep Thinking ON → Sonnet, OFF → Haiku)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_THINKING=claude-sonnet-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5

# Google Gemini (optional fallback)
GEMINI_API_KEY=AIza...

# Serper.dev — web retrieval (Phase 2)
SERPER_API_KEY=...

# Jina Reader — optional fallback for JS-heavy / blocked pages.
# Leave blank to use the free no-key tier (rate-limited). A key raises the limit.
JINA_API_KEY=

# Server port (default 3001)
PORT=3001
